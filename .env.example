# ─────────────────────────────────────────────────────────────
# Resolvr — Environment Variables
# ─────────────────────────────────────────────────────────────
# Local dev:   cp .env.example .env  and fill in the REQUIRED block.
# Vercel:      add each REQUIRED var in Project → Settings → Environment Variables.
#              The OPTIONAL vars all have sane defaults; you only need them
#              if you want to override behavior.
#
# .env is gitignored. Never commit real keys.
# ─────────────────────────────────────────────────────────────


# ╔════════════════════════════════════════════════════════════╗
# ║  REQUIRED — production won't run without these             ║
# ╚════════════════════════════════════════════════════════════╝

# Baseten — powers every LLM call in the pipeline (stages 2, 4, 5)
# and the live Revenue + Risk advisors. Get one at https://baseten.co.
BASETEN_API_KEY=

# You.com — powers stage 3 grounding (live market benchmarks).
# Get one at https://api.you.com.
YOUCOM_API_KEY=

# Vercel Blob — required ON VERCEL for shareable /?case={id} URLs.
# Without it, completed runs won't persist between requests.
# Generate via: Vercel project → Storage → Create Blob store → copy the
# BLOB_READ_WRITE_TOKEN it gives you.
# Local dev: leave blank. Cases are written to backend/data/cases/ on disk.
BLOB_READ_WRITE_TOKEN=


# ╔════════════════════════════════════════════════════════════╗
# ║  OPTIONAL — sane defaults, override only if you need to    ║
# ╚════════════════════════════════════════════════════════════╝

# Baseten model. Default works for the demo.
BASETEN_MODEL_ID=openai/gpt-oss-120b
BASETEN_BASE_URL=https://inference.baseten.co/v1

# Frontend → backend wiring.
# Local dev: defaults to http://localhost:8000.
# Vercel multi-service: leave blank — the proxy uses VERCEL_URL + /_/backend.
# Override only if you split the backend onto a different host.
NEXT_PUBLIC_BACKEND_URL=

# Mock flags — flip to "true" to bypass real API calls when testing UI only.
USE_MOCK_PIPELINE=false
USE_MOCK_GROUNDING=false


# ╔════════════════════════════════════════════════════════════╗
# ║  NOT NEEDED AT RUNTIME                                     ║
# ╚════════════════════════════════════════════════════════════╝
# Veris is CLI-only and used pre-deployment to grade the agents.
# Never called from the live service. Keep this in your local .env if
# you re-run veris simulations; do NOT add it to Vercel.
VERIS_API_KEY=
