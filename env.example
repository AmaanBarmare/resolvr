# ─────────────────────────────────────────────────────────────
# Resolvr — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# Never commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────


# ── BASETEN ───────────────────────────────────────────────────
# Production inference layer for all Claude API calls
# Sign up at https://baseten.co
# Dashboard → API Keys → Create key

BASETEN_API_KEY=

# Model to use for all pipeline stages
# Use the exact model string from your Baseten deployment
# Default: claude-sonnet-4-5 (fast, good quality for hackathon)
BASETEN_MODEL_ID=claude-sonnet-4-5


# ── YOU.COM ───────────────────────────────────────────────────
# Live market grounding — Stage 3 of the pipeline
# Sign up at https://you.com/api
# Dashboard → API Keys → Generate

YOUCOM_API_KEY=


# ── VERIS AI ──────────────────────────────────────────────────
# Agent sandbox — used ONLY for the pre-run setup (not live demo)
# Sign up at https://veris.ai
# Dashboard → Settings → API Keys
#
# You only need this to run:
#   veris login YOUR_VERIS_API_KEY
#   veris env push
#   veris simulations create
#
# The live demo reads pre-saved transcripts from disk.
# Veris is never called at runtime.

VERIS_API_KEY=


# ── BACKEND ───────────────────────────────────────────────────
# FastAPI server config

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Path to the data directory (relative to backend/)
DATA_DIR=data

# Max tokens for each Claude call per stage
FORENSICS_MAX_TOKENS=2000
SIMULATION_MAX_TOKENS=1500
BRIEF_MAX_TOKENS=2500

# You.com search — max results per query
YOUCOM_MAX_RESULTS=5

# Pipeline timeout per stage in seconds
STAGE_TIMEOUT_SECONDS=30


# ── FRONTEND ──────────────────────────────────────────────────
# Next.js config

# URL of the FastAPI backend (used by the SSE proxy route)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# For deployment (leave blank for local dev)
NEXT_PUBLIC_APP_URL=


# ── DEVELOPMENT FLAGS ─────────────────────────────────────────
# Set to "true" to use mock data instead of real API calls
# Useful when you haven't set up all API keys yet

# Use pre-built mock transcripts instead of real Veris output
# Set to "true" if Veris isn't set up yet
USE_MOCK_TRANSCRIPTS=false

# Skip real You.com calls, return hardcoded grounding verdicts
# Set to "true" to test the UI without spending API credits
USE_MOCK_GROUNDING=false

# Skip real Baseten/Claude calls, return hardcoded stage outputs
# Set to "true" to test the UI pipeline timing only
USE_MOCK_PIPELINE=false


# ── NOTES ─────────────────────────────────────────────────────
#
# Minimum required to run the full live demo:
#   BASETEN_API_KEY    ← required for Stages 2, 4, 5
#   YOUCOM_API_KEY     ← required for Stage 3
#
# Required for the Veris pre-run (morning of demo):
#   VERIS_API_KEY      ← required for veris login
#   BASETEN_API_KEY    ← also used inside the Veris agents
#   BASETEN_MODEL_ID   ← also used inside the Veris agents
#
# If you just want to test the UI without any API calls:
#   Set USE_MOCK_PIPELINE=true and USE_MOCK_GROUNDING=true
#   Then run: python scripts/generate_mock_transcripts.py
